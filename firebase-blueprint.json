{
  "entities": {
    "Metadata": {
      "title": "Metadata",
      "description": "App metadata such as latest APK URL",
      "type": "object",
      "properties": {
        "latestApkUrl": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    }
  },
  "firestore": {
